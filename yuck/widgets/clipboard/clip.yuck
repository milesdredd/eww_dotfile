(defwindow calender
  :monitor "eDP-1"
  :geometry (geometry :x "1550px" :y "520px" :width "350px" :height "550px")
  :anchor "center"
  :exclusive "true"
  :stacking "bg"
  :focusable "true"
  ;:windowtype "normal"
  :visible true
  :type "toolbar"
  (calender-box )
)
(defwidget calender-box []
    (eventbox :class "new clipboard"
        (box :class "new"
            
        )
    )
)